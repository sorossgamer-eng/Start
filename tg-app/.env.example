# Шаблон переменных окружения для Telegram Mini App
# Скопируй этот файл в .env и заполни своими данными
# Файл .env НЕ коммитится в Git (он в .gitignore)

# Токен бота — получить у @BotFather
BOT_TOKEN=

# Ссылка на Mini App (уже задеплоено на GitHub Pages)
MINI_APP_URL=https://sorossgamer-eng.github.io/Start/tg-app/index.html

# Куда отправлять заявки (когда добавите бэкенд)
# WEBHOOK_URL=https://ваш-сервер.ru/api/leads
